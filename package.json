{
  "name": "run-template-3d-react",
  "version": "1.0.0",
  "description": "Three.js + React UI + Vite + TypeScript template with RundotGameAPI integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "_build": "tsc && vite build",
    "build": "npm run _build",
    "build:bundled": "cross-env RUNDOT_GAME_DISABLE_EMBEDDED_LIBS=true npm run _build",
    "preview": "vite preview",
    "deploy": "npm run build && rundot deploy",
    "format": "prettier \"{src,public}/**/*.{ts,tsx,js,jsx,json,css,html}\" --write",
    "format:check": "prettier \"{src,public}/**/*.{ts,tsx,js,jsx,json,css,html}\" --check"
  },
  "keywords": [
    "react",
    "vite",
    "typescript",
    "three.js",
    "RUN.game"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE.txt",
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/three": "~0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@series-inc/rundot-game-sdk": "^5.9.9",
"@series-inc/stowkit-three-loader": "^0.1.43",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "~0.170.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@series-inc/rundot-game-sdk"
    ]
  }
}
